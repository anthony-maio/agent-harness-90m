# Copy this to .env and fill in your provider key.
# The harness uses litellm, so any supported provider works:
#   OpenAI, Anthropic, Ollama, OpenRouter, Azure, etc.
#
# Examples:
#   OPENAI_API_KEY=sk-...
#   ANTHROPIC_API_KEY=sk-ant-...
#   OPENROUTER_API_KEY=sk-or-...
#
# For local models via Ollama, no key is needed -- just set:
#   model.provider: "ollama"
#   model.name: "llama3.2"
# in harness.yaml.

OPENAI_API_KEY=
